{
  "name": "wodlab-backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "postinstall": "node -e \"try{require('fs').unlinkSync(require('path').join(process.cwd(),'node_modules','openai','src','tsconfig.json'));}catch(e){}\"",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc && node -e \"const fs=require('fs'),path=require('path');const d=path.join(process.cwd(),'dist','domain','prompts');fs.mkdirSync(d,{recursive:true});fs.copyFileSync(path.join(process.cwd(),'src','domain','prompts','programmingSystem.txt'),path.join(d,'programmingSystem.txt'));\"",
    "start": "node dist/server.js",
    "test": "jest"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.10.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-rate-limit": "^8.2.1",
    "groq-sdk": "^0.37.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.0",
    "typescript": "^5.7.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0"
  },
  "overrides": {
    "minimatch": ">=10.2.1"
  }
}
